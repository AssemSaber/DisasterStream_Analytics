  create  table "disaster"."marts"."dim_location"
  as (
    

with rnk_location as(
    select row_number() over(partition by location order by disaster_id ) as rnk , location 
    from "disaster"."intermediate"."inter_disaster"
), unique_row as(

    select rnk,location from rnk_location 
            where rnk=1
), max_sk as (
    
        select 0 as max_key
    
)
select
    rnk + (select max_key from max_sk) as location_sk,
    location
    from unique_row
  );
  
  
