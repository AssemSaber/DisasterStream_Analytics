with rnk_location as(
    select row_number() over(partition by location order by location ) as rnk , location 
    from "disaster"."intermediate"."inter_disaster"
), unique_row as(

    select location from rnk_location 
    where rnk=1
    
    and location not in (select location from "disaster"."marts"."dim_location")
    

),
max_sk as (
    
